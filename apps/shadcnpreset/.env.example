DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
BETTER_AUTH_URL=http://localhost:4010
BETTER_AUTH_SECRET=replace-with-a-long-random-string
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:4010
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# Smart search + AI assistant: OPENAI_API_KEY enables query embedding vs precomputed
# preset vectors. Generate vectors once: `pnpm generate:preset-embeddings` (writes
# data/preset-embeddings.json; fast at runtime — one embed() per search only).
OPENAI_API_KEY=
# OPENAI_SEARCH_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
