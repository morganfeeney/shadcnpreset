{
  "name": "shadcnpreset",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter=shadcn build && next dev --turbopack --port 4010",
    "build": "pnpm --filter=shadcn build && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.1.0",
    "clsx": "^2.1.1",
    "next": "16.1.7",
    "next-themes": "0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "workspace:*",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
