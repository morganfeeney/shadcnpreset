{
  "name": "shadcnpreset",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter=shadcn build && next dev --turbopack --port 4010",
    "build": "pnpm --filter=shadcn build && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:search": "node --import tsx/esm ./scripts/verify-search.ts",
    "generate:preset-embeddings": "node --import tsx/esm ./scripts/generate-preset-embeddings.ts",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@base-ui/react": "1.1.0",
    "@hugeicons/core-free-icons": "^1.2.1",
    "@hugeicons/react": "^1.1.1",
    "@next/third-parties": "^16.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@remixicon/react": "^4.7.0",
    "@tabler/icons-react": "^3.31.0",
    "@tanstack/react-query": "^5.95.2",
    "ai": "^6.0.158",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jotai": "^2.15.0",
    "lucide-react": "1.7.0",
    "next": "16.1.7",
    "next-themes": "0.4.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "workspace:*",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.1.9"
  }
}
